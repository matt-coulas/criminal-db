# criminal-db environment (copy to .env and export before running)

# Harvester
# CRIMINAL_DB_USER_AGENT=criminal-db/0.1 (+https://github.com/example/criminal-db)
# CRIMINAL_DB_RESPECT_ROBOTS=1
# CRIMINAL_DB_DELAY_MIN=5.0
# CRIMINAL_DB_DELAY_MAX=9.0

# Embeddings
# CRIMINAL_DB_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# CRIMINAL_DB_EMBEDDING_DIM=384

# Search / API limits
# CRIMINAL_DB_MAX_QUERY_LEN=500
# CRIMINAL_DB_API_HOST=127.0.0.1
# CRIMINAL_DB_API_PORT=8765
# CRIMINAL_DB_API_TOKEN=change-me-for-local-api
