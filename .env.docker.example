# Copy to .env beside compose.yaml (or export before docker compose up).

# Host port mapped to the JSON HTTP API (criminal-db serve). There is no browser UI yet.
CRIMINAL_DB_HOST_PORT=8765

# Host directories mounted into the container (gitignored locally; create empty dirs or use your corpus)
CRIMINAL_DB_DATA_DIR=./data
CRIMINAL_DB_DB_DIR=./db
CRIMINAL_DB_MODELS_DIR=./models

# API bind (inside container — use 0.0.0.0 so port publishing works)
CRIMINAL_DB_API_HOST=0.0.0.0
CRIMINAL_DB_API_PORT=8765
# CRIMINAL_DB_API_TOKEN=change-me

# Harvester / embeddings (optional)
# CRIMINAL_DB_USER_AGENT=criminal-db/0.2 (+https://github.com/matt-coulas/criminal-db)
# CRIMINAL_DB_RESPECT_ROBOTS=1
# CRIMINAL_DB_DELAY_MIN=5.0
# CRIMINAL_DB_DELAY_MAX=9.0
# CRIMINAL_DB_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
# CRIMINAL_DB_EMBEDDING_DIM=384
# CRIMINAL_DB_MAX_QUERY_LEN=500
