# Copy to .env for docker compose:  cp .env.docker.example .env

# Host paths (bind mounts)
CORPUS_DATA_PATH=./data
CORPUS_DB_PATH=./db
CORPUS_MODELS_PATH=./models

# Published ports on the host
API_PORT=8765
WEB_UI_PORT=8080

# API authentication (optional; leave empty for local use)
API_TOKEN=

# In-container settings (usually leave as-is)
CRIMINAL_DB_API_PORT=8765
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
MAX_QUERY_LEN=500
RESPECT_ROBOTS=1
